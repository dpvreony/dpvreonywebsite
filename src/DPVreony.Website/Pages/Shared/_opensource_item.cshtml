@model DPVreony.Website.Features.OpenSource.InvolvementModel

<div style="background-color: rgba(255, 255, 255, 0.4)">
    <div>
        <h4>@Model.Title</h4>
    </div>
    <div style="margin-bottom: 2em;">
        <p>@Model.Description</p>
        @if (@Model.GithubProject != null)
        {
            <a href="@Model.GithubProject.Uri" class="btn btn-primary">@Model.GithubProject.Name</a>
        }

        @if (@Model.Articles != null && @Model.Articles.Length > 0)
        {
            @foreach (var article in @Model.Articles)
            {
                <a href="@article.Uri" class="btn btn-primary">@article.Title</a>
            }
        }
    </div>
</div>

