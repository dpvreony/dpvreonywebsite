@using Whipstaff.NodaTime
<table>
    <tr>
        <th>Article Status</th>
        <td>@Model.Status.ToString()</td>
    </tr>
    <tr>
        <th>Article Version</th>
        <td>@Model.Version.ToString()</td>
    </tr>
    <tr>
        <th>First Written</th>
        <td>@Model.FirstRevision.ToYearMonthDayString()</td>
    </tr>
    <tr>
        <th>Last Revision</th>
        <td>@Model.LastRevision.ToYearMonthDayString()</td>
    </tr>
    <tr>
        <th>Next Review</th>
        <td>@Model.NextReview.ToYearMonthDayString()</td>
    </tr>
    <tr>
        <th>License</th>
        <td>MIT</td>
    </tr>
</table>

@code{
    [Parameter]
    public required DPVreony.Website.Features.Articles.ArticleMetadataModel Model { get; set; }
}
